{
    "release-type": "go-yoshi",
    "include-component-in-tag": true,
    "tag-separator": "/",
    "packages": {
        ".": {
            "component": "."
        },
        "auth": {
            "component": "auth"
        },
        "auth/oauth2adapt": {
            "component": "auth/oauth2adapt"
        },
        "bigquery": {
            "component": "bigquery"
        },
        "bigquery/v2": {
            "component": "bigquery/v2"
        },
        "bigtable": {
            "component": "bigtable"
        },
        "datastore": {
            "component": "datastore"
        },
        "errorreporting": {
            "component": "errorreporting"
        },
        "firestore": {
            "component": "firestore"
        },
        "logging": {
            "component": "logging"
        },
        "profiler": {
            "component": "profiler"
        },
        "pubsub": {
            "component": "pubsub"
        },
        "pubsub/v2": {
            "component": "pubsub/v2"
        },
        "pubsublite": {
            "component": "pubsublite"
        },
        "spanner": {
            "component": "spanner"
        },
        "spanner/test/opentelemetry/test": {
            "component": "spanner/test/opentelemetry/test"
        },
        "storage": {
            "component": "storage"
        },
        "vertexai": {
            "component": "vertexai"
        }
    },
    "plugins": [
        "sentence-case"
    ]
}
