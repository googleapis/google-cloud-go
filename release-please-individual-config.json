{
  "include-component-in-tag": true,
  "packages": {
    "agentplatform": {
      "component": "agentplatform"
    },
    "auth": {
      "component": "auth",
      "exclude-paths": [
        "auth/oauth2adapt"
      ]
    },
    "auth/oauth2adapt": {
      "component": "auth/oauth2adapt"
    },
    "bigquery": {
      "component": "bigquery",
      "exclude-paths": [
        "bigquery/v2"
      ]
    },
    "bigquery/v2": {
      "component": "bigquery"
    },
    "bigtable": {
      "component": "bigtable"
    },
    "compute/metadata": {
      "component": "compute/metadata"
    },
    "datastore": {
      "component": "datastore"
    },
    "firestore": {
      "component": "firestore"
    },
    "pubsub": {
      "component": "pubsub",
      "exclude-paths": [
        "pubsub/v2"
      ]
    },
    "pubsub/v2": {
      "component": "pubsub"
    },
    "pubsublite": {
      "component": "pubsublite"
    },
    "spanner": {
      "component": "spanner"
    },
    "storage": {
      "component": "storage"
    },
    "vertexai": {
      "component": "vertexai"
    }
  },
  "plugins": [
    "sentence-case"
  ],
  "release-type": "go-librarian",
  "separate-pull-requests": true,
  "tag-separator": "/"
}
